# 環境設定（APIキー）
.env
**/.env

# Python
__pycache__/
*.pyc
*.pyo

# 作業用データ（生データはgit管理しない・APIから再取得可能）
bi/data/raw/
bi/data/universe/
bi/data/processed/

# 生成物（出力データはGitに残さない）
bi/outputs/*.parquet
bi/outputs/*.xlsx
bi/outputs/notion_sync_state.json

# 清算物（将来削除予定の作業残骸）
python_investment/

# 生成されたミラー/作業ディレクトリ
github.com/

# Windows ジャンクション（Linux環境では不要）
bi/pipelines/data

# ログ・一時ファイル
*.log
*.tmp
*.tmp.parquet

# IDE
.vscode/
.cursor/
*.code-workspace

# Claude Code
.claude/settings.local.json
