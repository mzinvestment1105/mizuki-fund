# J-Quants API（scan_daily_movers / make_screening_master_v2 など）
JQUANTS_API_KEY=

# EDINET API（deep_dive.py / 有報・四半期報告書取得）
# 取得: https://api.edinet-fsa.go.jp/api/auth/index.aspx?mode=1
EDINET_API_KEY=

# OpenAI（レポート本文・画像からの銘柄読み取り）
OPENAI_API_KEY=
# 任意: チャットモデル（既定 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini
# 任意: 画像理解用（マルチモーダル対応モデル）
# OPENAI_VISION_MODEL=gpt-4o-mini

# Tavily Web Search API（report_mover_reasons / 画像レポートの検索）
# 取得: https://tavily.com/
TAVILY_API_KEY=

# Notion API（bi/pipelines/notion_incremental_sync.py ・単一DB差分同期）
# トークン: Notion のインテグレーション（内部インテグレーション）で発行
# DB ID: 対象データベースの URL に含まれる 32 文字（ハイフンありでも可）
# セットアップ補助: powershell -ExecutionPolicy Bypass -File .\ops\setup_notion_sync.ps1
NOTION_API_TOKEN=
NOTION_DATABASE_ID=
# 任意: 初回のみ遡る日数（state 無し時。既定 30）
# NOTION_INITIAL_DAYS=30
# 任意: 出力するプロパティ名をカンマ区切り（空なら全プロパティ。ページ本文は取得しない）
# NOTION_SYNC_PROPERTIES=名前,ステータス,タグ
# 任意: state / parquet の保存先（相対は bi/pipelines から）
# NOTION_SYNC_STATE_PATH=../outputs/notion_sync_state.json
# NOTION_SYNC_OUTPUT_PATH=../outputs/notion_db_incremental.parquet
