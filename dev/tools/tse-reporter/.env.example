# Anthropic API Key（screenshot / screener で使用。material コマンドでは不要）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# J-Quants API v2（x-api-key）
JQUANTS_REFRESH_TOKEN=your_jquants_api_key_here

# Google Custom Search JSON API（material コマンドで使用）
# https://developers.google.com/custom-search/v1/overview
#
# 必須: Google Cloud Console で「Custom Search API」を有効にする
# https://console.cloud.google.com/apis/library/customsearch.googleapis.com
# （有効にしないと HTTP 403 "does not have the access to Custom Search JSON API" になる）
#
# APIキー（別名: GOOGLE_CSE_API_KEY）— 上記 API を有効にした**同じプロジェクト**で作成したキー
GOOGLE_API_KEY=
# 検索エンジンID / cx（別名: GOOGLE_CSE_ID, GOOGLE_CUSTOM_SEARCH_ENGINE_ID, GOOGLE_SEARCH_ENGINE_ID）
GOOGLE_CSE_CX=

# Report Settings
REPORT_OUTPUT_DIR=./reports
REPORT_FORMAT=markdown  # markdown or html
